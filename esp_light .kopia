  - platform: template
    name: "GROW Start Offset (min)"
    id: grow_offset_start_ui
    min_value: 0
    max_value: 120
    step: 5
    unit_of_measurement: "min"
    restore_value: true
    initial_value: 60
    optimistic: true
    on_value:
      then:
        - lambda: 'id(g_grow_offset_start) = (int)x;'

