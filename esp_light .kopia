  - platform: rgb
    name: "Oświetlenie RGB"
    red: out_red
    green: out_green
    blue: out_blue
    id: light_rgb
    restore_mode: RESTORE_DEFAULT_OFF



display:
  - platform: ssd1306_i2c
    model: "SSD1306 128x64"
    address: 0x3C
    update_interval: 1s # Odciążamy procesor
    lambda: |-
      // --- NAGŁÓWEK (Zawsze widoczny) ---
      it.strftime(0, 0, id(font_small), "%Y-%m-%d  %H:%M:%S", id(ds_time).now());
      it.line(0, 13, 127, 13); 
      //it.draw_line(0, 12, 127, 12); // Używamy draw_line zamiast line (często szybciej)


      bool show_main = (id(ds_time).now().second % 10 < 5);
      // Logika przełączania widoków (5 sekund na widok)
      if (show_main) {
        // --- EKRAN 1: LAMPY GŁÓWNE (L1-L6) ---
        //it.print(0, 16, id(font_small), "GŁÓWNE (L1-L6)");
        
        it.printf(0, 16, id(font_small), "Wsch: %02.0f:%02.0f-%02.0f:%02.0f", 
                  id(h_start_sunrise).state, id(m_start_sunrise).state,
                  id(h_end_sunrise).state, id(m_end_sunrise).state);

        it.printf(0, 31, id(font_small), "Zach: %02.0f:%02.0f-%02.0f:%02.0f", 
                  id(h_start_sunset).state, id(m_start_sunset).state,
                  id(h_end_sunset).state, id(m_end_sunset).state);

        it.printf(0, 44, id(font_small), "Lampy: %.0f%%  Tr:%s", 
                  id(lampa1).remote_values.get_brightness() * 100.0,
                  id(auto_l1).state ? "AUTO" : "MAN");

      } else {
        // --- EKRAN 2: PANEL TŁO (L7) ---
        //it.print(0, 16, id(font_small), "TŁO (Panel L7)");

        it.printf(0, 16, id(font_small), "Wsch: %02.0f:%02.0f-%02.0f:%02.0f", 
                  id(l7_h_start_sunrise).state, id(l7_m_start_sunrise).state,
                  id(l7_h_end_sunrise).state, id(l7_m_end_sunrise).state);

        it.printf(0, 31, id(font_small), "Zach: %02.0f:%02.0f-%02.0f:%02.0f", 
                  id(l7_h_start_sunset).state, id(l7_m_start_sunset).state,
                  id(l7_h_end_sunset).state, id(l7_m_end_sunset).state);

        it.printf(0, 44, id(font_small), "Tło: %.0f%%  Tryb:%s", 
                  id(lampa7).remote_values.get_brightness() * 100.0,
                  id(auto_l7).state ? "AUTO" : "MAN");
      }





font:
  - file: "gfonts://Roboto"
    id: font_small
    size: 12
    # antialias: false
    glyphs: 
      # Poniżej w cudzysłowie jest spacja oraz wszystkie standardowe znaki i polskie litery
      - " ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789.,-_:;()!%/ąćęłńóśźżĄĆĘŁŃÓŚŹŻ"



text_sensor:
  - platform: template
    name: "Czas z Internetu (NTP)"
    id: ntp_time_www
    icon: "mdi:clock-outline"
    update_interval: 10s
    lambda: |-
      return id(sntp_time).now().strftime("%Y-%m-%d %H:%M:%S");

  - platform: template
    name: "Czas z Modułu (RTC)"
    id: rtc_time_www
    icon: "mdi:chip"
    update_interval: 10s
    lambda: |-
      return id(ds_time).now().strftime("%Y-%m-%d %H:%M:%S");

  # --- SYNC LAMPY GŁÓWNE ---
  - platform: homeassistant
    id: sync_start_sunrise
    entity_id: input_datetime.akwarium_start_poranka
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_h_start_sunrise) = h; id(g_m_start_sunrise) = m;
              id(h_start_sunrise).publish_state(h); id(m_start_sunrise).publish_state(m);
            }

  - platform: homeassistant
    id: sync_end_sunrise
    entity_id: input_datetime.akwarium_koniec_poranka
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_h_end_sunrise) = h; id(g_m_end_sunrise) = m;
              id(h_end_sunrise).publish_state(h); id(m_end_sunrise).publish_state(m);
            }

  - platform: homeassistant
    id: sync_start_sunset
    entity_id: input_datetime.akwarium_start_zachodu
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_h_start_sunset) = h; id(g_m_start_sunset) = m;
              id(h_start_sunset).publish_state(h); id(m_start_sunset).publish_state(m);
            }

  - platform: homeassistant
    id: sync_end_sunset
    entity_id: input_datetime.akwarium_koniec_zachodu
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_h_end_sunset) = h; id(g_m_end_sunset) = m;
              id(h_end_sunset).publish_state(h); id(m_end_sunset).publish_state(m);
            }

  # --- SYNC LAMPA TŁO (L7) ---
  - platform: homeassistant
    id: sync_l7_start_sunrise
    entity_id: input_datetime.tlo_start_poranka
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_l7_h_start_sunrise) = h; id(g_l7_m_start_sunrise) = m;
              id(l7_h_start_sunrise).publish_state(h); id(l7_m_start_sunrise).publish_state(m);
            }

  - platform: homeassistant
    id: sync_l7_end_sunrise
    entity_id: input_datetime.tlo_koniec_poranka
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_l7_h_end_sunrise) = h; id(g_l7_m_end_sunrise) = m;
              id(l7_h_end_sunrise).publish_state(h); id(l7_m_end_sunrise).publish_state(m);
            }

  - platform: homeassistant
    id: sync_l7_start_sunset
    entity_id: input_datetime.tlo_start_zachodu
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_l7_h_start_sunset) = h; id(g_l7_m_start_sunset) = m;
              id(l7_h_start_sunset).publish_state(h); id(l7_m_start_sunset).publish_state(m);
            }

  - platform: homeassistant
    id: sync_l7_end_sunset
    entity_id: input_datetime.tlo_koniec_zachodu
    on_value:
      then:
        - lambda: |-
            int h, m;
            if (sscanf(x.c_str(), "%d:%d", &h, &m) >= 2) {
              id(g_l7_h_end_sunset) = h; id(g_l7_m_end_sunset) = m;
              id(l7_h_end_sunset).publish_state(h); id(l7_m_end_sunset).publish_state(m);
            }






switch:
  - platform: template
    name: "Lampa 1 - Auto"
    id: auto_l1
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON
    icon: "mdi:robot"
  - platform: template
    name: "Lampa 2 - Auto"
    id: auto_l2
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON
    icon: "mdi:robot"
  - platform: template
    name: "Lampa 3 - Auto"
    id: auto_l3
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON
    icon: "mdi:robot"
  - platform: template
    name: "Lampa 4 - Auto"
    id: auto_l4
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON
    icon: "mdi:robot"
  - platform: template
