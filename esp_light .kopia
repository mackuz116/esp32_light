interval:
  - interval: 1min
    then:
      - lambda: |-
          auto now = id(ds_time).now();
          if (!now.is_valid()) return;
          int cur = now.hour * 60 + now.minute;
          static bool is_first_run = true;

          // --- LOGIKA CHMUR (Tylko dla L1-L6) ---
          float cloud_factor = 1.0f; 
          // Sprawdzamy, czy przełącznik chmur w HA jest włączony
          if (id(chmury_on_off).state) {
            // Używamy minuty jako ziarna, aby wszystkie lampy ściemniły się jednocześnie
            srand(now.hour * 60 + now.minute);
            if ((rand() % 100) < 15) { // 15% szans na chmurę w danej minucie
              cloud_factor = 0.65f;    // Przyciemnienie o 35%
            }
          }

          // Funkcja obliczająca bazową jasność (0.0 - 1.0)
          auto calc = [&](int su, int eu, int sd, int ed) -> float {
            if (cur >= eu && cur < sd) return 1.0f; 
            if (cur >= su && cur < eu) return (float)(cur - su) / (float)(eu - su);
            if (cur >= sd && cur < ed) return 1.0f - (float)(cur - sd) / (float)(ed - sd);
            return 0.0f;
          };

          // 1. Obliczamy czasy BIAŁYCH (L1, L3, L4, L6)
          int s_u = id(g_h_start_sunrise) * 60 + id(g_m_start_sunrise);
          int e_u = id(g_h_end_sunrise) * 60 + id(g_m_end_sunrise);
          int s_d = id(g_h_start_sunset) * 60 + id(g_m_start_sunset);
          int e_d = id(g_h_end_sunset) * 60 + id(g_m_end_sunset);
          float br_white = calc(s_u, e_u, s_d, e_d);

          // 2. Obliczamy czasy GROW (L2, L5) - przesunięcie całego okna o offset
          float br_grow = calc(s_u - id(g_grow_offset_start), 
                               e_u - id(g_grow_offset_start), 
                               s_d + id(g_grow_offset_end), 
                               e_d + id(g_grow_offset_end));

          // 3. Obliczenia dla Tła (L7) - niezależne godziny
          float br_l7 = calc(id(g_l7_h_start_sunrise) * 60 + id(g_l7_m_start_sunrise),
                             id(g_l7_h_end_sunrise) * 60 + id(g_l7_m_end_sunrise),
                             id(g_l7_h_start_sunset) * 60 + id(g_l7_m_start_sunset),
                             id(g_l7_h_end_sunset) * 60 + id(g_l7_m_end_sunset));

          // Funkcja aplikująca jasność
          auto apply = [&](light::LightState* l, float b, bool auto_m, float pwr_val, bool allow_clouds) {
            if (auto_m) {
              float target = b * (pwr_val / 100.0f);
              
              // Chmury tylko jeśli lampa na to pozwala i faktycznie świeci
              if (allow_clouds && target > 0.05f) {
                target *= cloud_factor;
              }

              // Zabezpieczenie termiczne (bezpiecznik)
              if (id(esp_temp).state > 72.0) target *= 0.8;

              float current = l->remote_values.get_brightness();
              if (abs(current - target) > 0.001f || is_first_run) {
                auto call = l->make_call();
                call.set_brightness(target);
                call.set_state(target > 0.001f);
                call.set_transition_length(is_first_run ? 5000 : 59000);
                call.perform();
              }
            }
          };

          // --- REALIZACJA ---
          // Białe: Harmonogram główny + Chmury
          apply(id(lampa1), br_white, id(auto_l1).state, id(g_pwr_l1), true);
          apply(id(lampa3), br_white, id(auto_l3).state, id(g_pwr_l3), true);
          apply(id(lampa4), br_white, id(auto_l4).state, id(g_pwr_l4), true);
          apply(id(lampa6), br_white, id(auto_l6).state, id(g_pwr_l6), true);

          // GROW: Harmonogram z offsetem + Chmury
          apply(id(lampa2), br_grow,  id(auto_l2).state, id(g_pwr_l2), true);
          apply(id(lampa5), br_grow,  id(auto_l5).state, id(g_pwr_l5), true);

          // TŁO: Harmonogram własny + BRAK CHMUR
          apply(id(lampa7), br_l7,    id(auto_l7).state, id(g_pwr_l7), false);

          is_first_run = false;