  # --- MOCE INDYWIDUALNE DLA KAŻDEJ LAMPY (Boxy) ---
  - platform: template
    name: "Moc Max Lampa 1 (%)"
    id: pwr_l1
    min_value: 0
    max_value: 100
    step: 1
    mode: box
    # optimistic: true
    lambda: "return id(g_pwr_l1);"
    # restore_value: yes
    # initial_value: 80
    # on_value:
    #   then:
    #     - lambda: |-
    #         float nb = x / 100.0;
    #         if (abs(id(lampa1).remote_values.get_brightness() - nb) > 0.005) {
    #           auto call = id(lampa1).make_call();
    #           call.set_brightness(nb);
    #           call.perform();
    #         }
    # set_action:
    #   then:
    #     - lambda: |-
    #         // 1. Zapisz do pamięci Flash (globals)
    #         id(g_pwr_l1) = x;

    #         float nb = x / 100.0;
    #         // Sprawdzamy tylko, czy nowa wartość różni się od obecnej na pasku
    #         if (abs(id(lampa1).remote_values.get_brightness() - nb) > 0.005) {
    #           auto call = id(lampa1).make_call();
    #           call.set_brightness(nb);
    #           // Opcjonalnie: jeśli chcesz, żeby box zmieniał jasność TYLKO gdy lampa świeci, 
    #           // zostawiamy call.perform(), ale usuwamy blokadę trybu AUTO.
    #           call.perform();
    #         }  
    set_action:
      then:
        - lambda: |-
            id(g_pwr_l1) = x; // Zapisz nową moc max do pamięci
            // Steruj lampą z boxa tylko jeśli AUTO jest wyłączone
            if (!id(auto_l1).state) {
              auto call = id(lampa1).make_call();
              call.set_brightness(x / 100.0f);
              call.perform();
            } else {
              // Jeśli AUTO jest włączone, po prostu zaktualizuj box w UI
              id(pwr_l1).publish_state(x);
            }  
  
