  - platform: template
    name: "08 Lampy koniec wieczora (m)"
    id: m_end_sunset
    min_value: 0
    max_value: 59
    step: 1
    mode: box
    # optimistic: true
    # restore_value: yes
    # initial_value: 0
    lambda: "return id(g_m_end_sunset);"
    
    # 2. ZAPIS (nie może być return)
    set_action:
      then:
        - lambda: |-
            id(g_m_end_sunset) = x; // Zapisz do pamięci
            id(m_end_sunset).publish_state(x); // Odśwież widok w HA


