    id: cloud_simulation_switch
    optimistic: true
    restore_mode: RESTORE_DEFAULT_OFF
    entity_category: config
    icon: "mdi:cloud-sync"


number:
  # --- GRUPA GŁÓWNA (L1 - L6) ---
  - platform: template
    name: "01 Lampy start poranka (h)"
    id: h_start_sunrise
    min_value: 0
    max_value: 23
    step: 1
    mode: box
    # optimistic: true
    # restore_value: yes
    # initial_value: 10
    lambda: "return id(g_h_start_sunrise);"
    
    # 2. ZAPIS (nie może być return)
    set_action:
      then:
        - lambda: |-
            id(g_h_start_sunrise) = x; // Zapisz do pamięci
            id(h_start_sunrise).publish_state(x); // Odśwież widok w HA

  - platform: template
    name: "02 Lampy start poranka (m)"
    id: m_start_sunrise
    min_value: 0
    max_value: 59
    step: 1
    mode: box
    # optimistic: true
    # restore_value: yes
    # initial_value: 30
    lambda: "return id(g_m_start_sunrise);"
    
    # 2. ZAPIS (nie może być return)
    set_action:
      then:
        - lambda: |-
            id(g_m_start_sunrise) = x; // Zapisz do pamięci
            id(m_start_sunrise).publish_state(x); // Odśwież widok w HA



  - platform: template
    name: "03 Lampy koniec poranka (h)"
    id: h_end_sunrise
    min_value: 0
    max_value: 23
    step: 1
    mode: box
    # optimistic: true
    # restore_value: yes
    # initial_value: 11
    lambda: "return id(g_h_end_sunrise);"
    
    # 2. ZAPIS (nie może być return)
    set_action:
